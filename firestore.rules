rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    // Unified staff check
    function isStaff() {
      return isSignedIn() && 
             (request.auth.token.email in [
               'admin@lphalghazali.com', 
               'auditor@lphalghazali.com', 
               'editor@lphalghazali.com', 
               'staf@lphalghazali.com',
               'asngad@mhs.unugha.ac.id'
             ] || (
               exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
               get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'pu') in ['admin', 'auditor', 'editor', 'staf']
             ));
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Collection Matches ---

    // 1. Users Collection
    match /users/{userId} {
      allow get: if isOwner(userId) || isStaff();
      allow list: if isStaff();
      
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isStaff();
      allow delete: if isStaff();
    }

    // 2. Artifacts & Public Data
    match /artifacts/{appId} {
      allow get: if true; 

      match /public/system_settings {
        allow read: if true;
        allow write: if isStaff();
      }

      match /public/data/berita/{beritaId} {
        allow read: if true;
        allow write: if isStaff();
      }

      match /public/data/pengajuan_halal/{pengajuanId} {
        allow read: if isStaff() || (isSignedIn() && resource.data.userId == request.auth.uid);
        allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
        allow update: if isStaff() || (isSignedIn() && resource.data.userId == request.auth.uid);
        allow delete: if isStaff();
      }
    }
  }
}
