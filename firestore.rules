rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    function getRole() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid)) 
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role 
        : null;
    }
    
    function isStaff() {
      let role = getRole();
      return role == 'admin' || role == 'auditor';
    }
    
    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    
    match /{document=**} {
      allow read, write: if false;
    }

    match /artifacts/{appId} {
      // System Settings
      match /public/system_settings {
        allow read: if true;
        allow write: if isSignedIn() && isStaff();
      }
      
      // Berita
      match /public/data/berita/{beritaId} {
        allow read: if true;
        allow write: if isSignedIn() && isStaff();
      }
      
      // Pengajuan Halal
      match /public/data/pengajuan_halal/{pengajuanId} {
        // PU only reads their own. Staff reads all.
        allow read: if isSignedIn() && (
          isStaff() || 
          resource.data.userId == request.auth.uid
        );
        
        allow create: if isSignedIn();
        // Allow PU to update their own, or Staff to update
        allow update: if isSignedIn() && (
          isStaff() || 
          resource.data.userId == request.auth.uid
        );
        
        allow delete: if isSignedIn() && isStaff();
      }
    }
    
    match /users/{userId} {
      // Users can read their own data.
      allow get: if isSignedIn() && isOwner(userId);
      // Let PU create their own profile, but enforce role='pu'. Staff roles created by admin.
      allow create: if isSignedIn() && isOwner(userId) && (
        request.resource.data.role == 'pu' || 
        (request.resource.data.role == 'admin' && request.auth.token.email == 'admin@lphalghazali.com') ||
        (request.resource.data.role == 'auditor' && request.auth.token.email == 'auditor@lphalghazali.com')
      );
      allow update: if isSignedIn() && isOwner(userId) && request.resource.data.role == resource.data.role; // Prevent role escalation
    }
  }
}

