rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function existing() {
      return resource.data;
    }

    function incoming() {
      return request.resource.data;
    }

    // Since we don't have Admin SDK, anyone authenticated using an admin email can be an admin
    // Or we allow arbitrary reads from system_settings for authentication
    match /artifacts/{appId}/public/system_settings {
      allow read: if true; // Allows the local client to check admin hashes
      allow write: if isSignedIn(); // We'll assume any signed in admin can write
    }

    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    match /artifacts/{appId}/public/pengajuan_halal/{pengajuanId} {
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      // You can only view your own or if you're staff (we'll just loosely allow staff by checking if they are not in the 'pu' collection, or simply allow list if isSignedIn since this is early setup)
      // Note: A strict rule would be:
      allow read: if isSignedIn() && (existing().userId == request.auth.uid || request.auth.token.email_verified == true || request.auth.uid != null); // Loose for now to allow staff
      allow update: if isSignedIn() && (existing().userId == request.auth.uid || request.auth.uid != null);
      allow delete: if isSignedIn() && existing().userId == request.auth.uid;
    }

    match /artifacts/{appId}/public/data/berita/{beritaId} {
      allow read: if true;
      allow write: if isSignedIn(); 
    }
  }
}

